{
    "name": "businessg/base-excel",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "excel",
        "export",
        "import",
        "framework-agnostic"
    ],
    "description": "Excel 同步/异步智能配置导入导出基础组件，可独立使用，支持无限极列头配置、页码、列头、列样式配置。",
    "autoload": {
        "psr-4": {
            "BusinessG\\BaseExcel\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*",
        "ext-redis": "*",
        "league/flysystem": "^3.0",
        "overtrue/http": "^1.2",
        "psr/container": "^1.0 || ^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "ramsey/uuid": "*",
        "symfony/console": "^6.0|^7.0"
    },
    "suggest": {
        "ext-xlswriter": "Required for XlsWriterDriver (default driver)",
        "predis/predis": "Use predis driver for progress storage (progress.driver=predis)"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.0",
        "phpunit/phpunit": ">=9.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
